# SoftBlobGIN blob visualization for 6C3Y
# Generated automatically — open in PyMOL

fetch 6c3y, async=0
remove not chain A
hide everything
show cartoon, chain A
color gray80, chain A

# Color residues by blob assignment
select blob1, chain A and resi 71+85+124+128+249+312+331+355+363+390+393+399+417
color red, blob1
# Blob 1: 13 residues, importance=0.7656
select blob2, chain A and resi 7+16+17+47+50+119+131+134+139+140+142+159+163+215+251+256+266+305+351+354+356+400+401+412+414+415+418+425+429+485
color orange, blob2
# Blob 2: 30 residues, importance=0.0039
select blob3, chain A and resi 15+44+82+83+101+122+165+168+252+274+275+277+306+309+310+349+359+360+408+423
color yellow, blob3
# Blob 3: 20 residues, importance=0.0000
select blob4, chain A and resi 8+11+13+22+37+40+45+80+93+97+117+130+135+144+158+160+248+253+255+268+284+292+302+314+329+340+341+342+365+388+395+397+404+406+411+467+471+472
color green, blob4
# Blob 4: 38 residues, importance=0.0039
select blob5, chain A and resi 18+43+120+127+133+136+143+167+178+250+269+271+296+301+304+338+344+345+407+420+433+484
color cyan, blob5
# Blob 5: 22 residues, importance=0.0039
select blob6, chain A and resi 88+137+161+276+300+308+343+348+352+362+389+391+403+422+426
color blue, blob6
# Blob 6: 15 residues, importance=0.0078
select blob7, chain A and resi 
color purple, blob7
# Blob 7: 283 residues, importance=0.1719
select blob8, chain A and resi 2+3+4+5+6+14+26+29+32+36+38+42+48+68+70+86+94+98+104+112+115+116+126+141+153+156+157+170+175+179+182+183+195+196+199+201+204+213+217+231+273+283+289+291+298+299+311+313+324+325+326+327+328+332+357+361+371+385+387+398+402+421+427+430+431+432+434+468+489
color white, blob8
# Blob 8: 69 residues, importance=0.0430

# Active/binding site residues
select active_site, chain A and resi 434+440+479+483
show sticks, active_site
color magenta, active_site
set stick_radius, 0.15, active_site

# Domain boundaries
# Domain 0: residues 73-140
# Domain 1: residues 350-418
# Domain 2: residues 172-331

# Final styling
set cartoon_transparency, 0.3
set ray_shadow, 0
bg_color white
orient
zoom chain A